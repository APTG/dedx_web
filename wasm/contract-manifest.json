{
  "_meta": {
    "purpose": "Single source of truth for JS-facing inverse-wrapper ABI symbols.",
    "consumers": [
      "wasm/verify.mjs",
      "scripts/check-wasm-contract-docs.cjs"
    ],
    "update_when": "Any inverse-wrapper export or inverse service backing symbol is added, removed, or renamed."
  },
  "exports": {
    "dedx_tools_flat_inverse": [
      "dedx_get_inverse_stp_flat",
      "dedx_get_inverse_csda_flat"
    ],
    "dedx_extra_inverse": [
      "dedx_get_bragg_peak_stp"
    ]
  },
  "serviceBacking": {
    "getInverseStp": [
      "dedx_get_inverse_stp_flat"
    ],
    "getInverseCsda": [
      "dedx_get_inverse_csda_flat"
    ],
    "getBraggPeakStp": [
      "dedx_get_bragg_peak_stp"
    ]
  }
}
