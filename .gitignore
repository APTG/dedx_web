# dependencies
/node_modules
/.pnp
.pnp.js
/.venv/

# testing
/coverage

# SvelteKit / Vite build output
/build
/.svelte-kit/

# misc
.DS_Store
__pycache__/
*.pyc
.env
.env.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# WASM build artifacts — build.sh outputs here; never commit built binaries
/static/wasm/libdedx.mjs
/static/wasm/libdedx.wasm

# Build artifacts — generated at build time
/static/deploy.json
/static/jsroot.min.js

# Generated external-data reference stores and inspection reports
/data/*.webdedx/
/data/srim-reference-inspection/
/data/srim-reference-conversion/

# AI tooling — local agent session state and credentials
# Keep .opencode/agents/, .opencode/prompts/ tracked; ignore only runtime task state
.opencode/tasks/
*.key

# Prototypes — throwaway spike code (Stage 2.5)
# Each spike has its own dependencies, build artifacts, etc.
prototypes/**/node_modules/
prototypes/**/.svelte-kit/
prototypes/**/build/
prototypes/*/libdedx.a
prototypes/*/preload/
prototypes/*/embed/
prototypes/*/pnpm-lock.yaml

# Playwright — CI uploads these as artifacts; do not commit
playwright-report/
test-results/
package-lock.json

# Playwright MCP — debug screenshots and session logs (browser_screenshot output lands here)
.playwright-mcp/
/*.png
/plot-page-screenshot