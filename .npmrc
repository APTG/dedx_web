# pnpm supply-chain policy: require packages to be at least 1 hour old before
# installation. The pnpm 11 default is 86400 (24 h), which causes Dependabot
# PRs to fail CI when the lockfile is committed within hours of the package
# being published. 3600 s (1 h) still provides meaningful protection against
# packages yanked or poisoned within minutes of publication.
minimum-release-age=3600
